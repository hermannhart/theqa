        {
          "sequence_length": 10000,
          "n_trials": 100,
          "n_sigmas": 50,
          "time_seconds": 21.847,
          "memory_mb": 156.8
        }
      ]
    },
    "spectral": {
      "description": "FFT-based spectral method",
      "complexity": "O(n log n)",
      "benchmarks": [
        {
          "sequence_length": 100,
          "time_seconds": 0.0002,
          "memory_mb": 2.1,
          "speedup_vs_empirical": 1170
