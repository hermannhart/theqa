  "algorithms": {
    "empirical": {
      "description": "Standard empirical method with Monte Carlo sampling",
      "complexity": "O(n × m × k)",
      "benchmarks": [
        {
          "sequence_length": 100,
          "n_trials": 100,
          "n_sigmas": 50,
          "time_seconds": 0.234,
          "memory_mb": 12.5
        },
        {
          "sequence_length": 1000,
          "n_trials": 100,
          "n_sigmas": 50,
          "time_seconds": 2.156,
          "memory_mb": 45.3
